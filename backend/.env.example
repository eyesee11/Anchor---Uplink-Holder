# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Google OAuth credentials — from Google Cloud Console → APIs & Services → Credentials
CLIENT_ID=your_google_client_id_here
CLIENT_SECRET=your_google_client_secret_here

# The URL Google redirects to after login
# Must be registered in Google Cloud Console → Authorized Redirect URIs
# For local dev: http://localhost:3000/auth/callback
# For production: https://your-deployed-domain.com/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# Port (Railway/Render set this automatically; leave as 3000 for local dev)
PORT=3000
